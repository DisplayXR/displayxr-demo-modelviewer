<?xml version="1.0" encoding="utf-8"?>
<!--
    Copyright 2026, Leia Inc.
    SPDX-License-Identifier: Apache-2.0

    Android leg of displayxr-demo-modelviewer. A vendor-neutral OpenXR client:
    no CNSDK, no SR SDK — it binds to whatever DisplayXR runtime is installed
    via the Khronos OpenXR loader broker. Per ADR-025 the runtime + vendor DP
    run OUT-OF-PROCESS (the in_process flavor is dev-only); the <queries> block
    below lets the loader discover + bind either flavor.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Android 12+ package-visibility: cross-package intent/provider queries
        return empty unless declared here. Without this the Khronos loader's
        broker lookup for org.khronos.openxr.runtime_broker returns a null
        cursor → xrCreateInstance fails XR_ERROR_RUNTIME_UNAVAILABLE (black
        screen), even with the runtime installed. (runtime#510, validated on
        nubia NP02J — commit 6c0f0941b.)
    -->
    <queries>
        <intent>
            <action android:name="org.khronos.openxr.OpenXRRuntimeService" />
        </intent>
        <provider
            android:authorities="org.khronos.openxr.runtime_broker;org.khronos.openxr.system_runtime_broker"
            tools:replace="android:authorities" />
        <!-- Both runtime flavors so the same APK runs against either:
             out_of_process (production, ADR-025) or in_process (dev). -->
        <package android:name="org.freedesktop.monado.openxr_runtime.out_of_process" />
        <package android:name="org.freedesktop.monado.openxr_runtime.in_process" />
        <!-- IPC bind to the out-of-process runtime service. -->
        <intent>
            <action android:name="org.freedesktop.monado.ipc.CONNECT" />
        </intent>
    </queries>

    <uses-feature
        android:glEsVersion="0x00030002"
        android:required="false" />

    <!--
        Long XR sessions generate no user-input events; without WAKE_LOCK the
        screen dims and the session pauses. (The OOP runtime service owns eye
        tracking / the camera — this vendor-neutral client requests no CAMERA.)
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="DisplayXR Model Viewer">

        <!--
            Orientation is NOT locked — the runtime + DP adapt the weave and
            view math per orientation and re-adapt on physical rotation.
            configChanges keeps the NativeActivity alive across rotations
            (the surface resizes instead of the activity recreating).
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:launchMode="singleTask">
            <meta-data
                android:name="android.app.lib_name"
                android:value="model_viewer_vk_android" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
